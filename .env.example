# подключение к Postgres (Supabase / Neon / локальный)
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"

# секрет NextAuth (сгенерировать: `npx auth secret` или openssl rand -base64 32)
AUTH_SECRET=""

# адрес деплоя/локалки — нужен для callback'ов NextAuth
NEXTAUTH_URL="http://localhost:3000"

# опционально: вход через Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
