# Supabase Postgres — пуллер для рантайма (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Прямое подключение к БД — для миграций Prisma (port 5432)
DIRECT_URL="postgresql://postgres.xxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# секрет NextAuth (сгенерировать: `npx auth secret` или openssl rand -base64 32)
AUTH_SECRET=""

# адрес деплоя/локалки — нужен для callback'ов NextAuth
NEXTAUTH_URL="http://localhost:3000"
